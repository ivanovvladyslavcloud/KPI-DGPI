<Window x:Class="Lab5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EDM Database Viewer"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <TabControl>

            <TabItem Header="Clients">

                <DataGrid x:Name="ClientsGrid"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          />
            </TabItem>
            
            
            <TabItem Header="Companies">

            <DataGrid x:Name="CompaniesGrid"
              AutoGenerateColumns="True"
              IsReadOnly="True"/>

            </TabItem>

            <TabItem Header="Rich Clients">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,10">

                        <TextBlock Text="Min income:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

                        <TextBox x:Name="IncomeBox"
                     Width="120"
                     Margin="0,0,10,0"/>

                        <Button Content="Search"
                    Width="100"
                    Click="Search_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="RichClientsGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"/>

                </Grid>

            </TabItem>

            <TabItem Header="By Company">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                        <TextBlock Text="Company ID:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

                        <TextBox x:Name="CompanyIdBox"
                     Width="120"
                     Margin="0,0,10,0"/>

                        <Button Content="Filter"
                    Width="100"
                    Click="FilterByCompany_Click"/>

                    </StackPanel>

                    <DataGrid x:Name="CompanyClientsGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="True"/>

                </Grid>

            </TabItem>

            <TabItem Header="Top Clients">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Content="Load Top 5"
                Width="150"
                Margin="0,0,0,10"
                Click="LoadTop_Click"/>

                    <DataGrid x:Name="TopClientsGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="True"/>

                </Grid>

            </TabItem>

        </TabControl>

    </Grid>
</Window>
