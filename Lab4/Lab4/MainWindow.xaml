<Window x:Class="Lab4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clients CRUD"
        Height="450" Width="700"
        WindowStartupLocation="CenterScreen">

    <DockPanel Margin="10">

        <ToolBar DockPanel.Dock="Top" Height="40">

            <Button Content="Create"
                    Width="80"
                    Margin="5"
                    Click="Create_Click"/>

            <Button Content="Update"
                    Width="80"
                    Margin="5"
                    Click="Update_Click"/>

            <Button Content="Delete"
                    Width="80"
                    Margin="5"
                    Click="Delete_Click"/>
        </ToolBar>

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="ListClients"
                     DisplayMemberPath="Name"
                     SelectionChanged="ListClients_SelectionChanged"
                     Grid.Column="0"/>

            <StackPanel Grid.Column="1" Margin="15">

                <TextBlock Text="Name"/>
                <TextBox x:Name="NameBox" Margin="0,0,0,10"/>

                <TextBlock Text="Phone"/>
                <TextBox x:Name="PhoneBox" Margin="0,0,0,10"/>

                <TextBlock Text="Address"/>
                <TextBox x:Name="AddressBox" Margin="0,0,0,10"/>

                <TextBlock Text="Order Amount"/>
                <TextBox x:Name="AmountBox" Margin="0,0,0,10"/>

            </StackPanel>

        </Grid>
    </DockPanel>
</Window>